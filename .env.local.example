# Brawlhalla v1 public API key.
# Request one at: https://dev.brawlhalla.com/
# Server-only — never expose to the client.
BRAWLHALLA_API_KEY=

# Supabase Postgres connection strings — grab from the dashboard "Connect" button.
# DATABASE_URL          = Transaction pooler (port 6543). Used at runtime on Vercel.
# DATABASE_URL_UNPOOLED = Session pooler or Direct connection (port 5432). Used by
#   drizzle-kit (db:push) and the node scripts. Both strings carry the DB password.
DATABASE_URL=
DATABASE_URL_UNPOOLED=

# Random string used to authenticate Vercel cron invocations.
# Vercel auto-generates one when you add crons; mirror it locally for testing.
CRON_SECRET=
